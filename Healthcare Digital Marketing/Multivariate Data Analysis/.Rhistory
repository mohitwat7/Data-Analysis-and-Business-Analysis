outlier_count <- function(x) {
Q1 <- quantile(x, 0.25)
Q3 <- quantile(x, 0.75)
IQR_val <- IQR(x)
lower <- Q1 - 1.5 * IQR_val
upper <- Q3 + 1.5 * IQR_val
sum(x < lower | x > upper)
}
sapply(data[num_cols], outlier_count)
(colSums(is.na(data))/nrow(data))*100
outlier_count <- function(x) {
Q1 <- quantile(x, 0.25, na.rm = TRUE)
Q3 <- quantile(x, 0.75, na.rm = TRUE)
IQR_val <- IQR(x, na.rm = TRUE)
lower <- Q1 - 1.5 * IQR_val
upper <- Q3 + 1.5 * IQR_val
sum(x < lower | x > upper, na.rm = TRUE)
}
sapply(data[, sapply(data, is.numeric) & names(data) != "Patient_ID"], outlier_count)
outlier_percent <- function(x) {
Q1 <- quantile(x, 0.25, na.rm = TRUE)
Q3 <- quantile(x, 0.75, na.rm = TRUE)
IQR_val <- IQR(x, na.rm = TRUE)
lower <- Q1 - 1.5 * IQR_val
upper <- Q3 + 1.5 * IQR_val
outliers <- sum(x < lower | x > upper, na.rm = TRUE)
total <- sum(!is.na(x))
percent <- (outliers / total) * 100
return(percent)
}
num_cols <- sapply(data, is.numeric)
num_cols["Patient_ID"] <- FALSE
sapply(data[num_cols], outlier_percent)
cap_outliers <- function(x) {
Q1 <- quantile(x, 0.25, na.rm = TRUE)
Q3 <- quantile(x, 0.75, na.rm = TRUE)
IQR_val <- IQR(x, na.rm = TRUE)
lower <- Q1 - 1.5 * IQR_val
upper <- Q3 + 1.5 * IQR_val
x[x < lower] <- lower
x[x > upper] <- upper
return(x)
}
data$Ad_Spend <- cap_outliers(data$Ad_Spend)
data$Revenue <- cap_outliers(data$Revenue)
View(data)
num_cols <- sapply(data, is.numeric)
num_data <- data[, num_cols]
colnames(num_data)
outlier_percent <- function(x) {
Q1 <- quantile(x, 0.25, na.rm = TRUE)
Q3 <- quantile(x, 0.75, na.rm = TRUE)
IQR_val <- IQR(x, na.rm = TRUE)
lower <- Q1 - 1.5 * IQR_val
upper <- Q3 + 1.5 * IQR_val
outliers <- sum(x < lower | x > upper, na.rm = TRUE)
total <- sum(!is.na(x))
percent <- (outliers / total) * 100
return(percent)
}
sapply(data[num_cols], outlier_percent)
